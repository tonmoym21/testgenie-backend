{
  "name": "testgenie-backend",
  "version": "0.1.0",
  "description": "TestGenie Backend MVP - AI-powered QA automation platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate:up": "node-pg-migrate up --migration-file-language sql --migrations-dir migrations",
    "migrate:down": "node-pg-migrate down --migration-file-language sql --migrations-dir migrations",
    "migrate:create": "node-pg-migrate create --migration-file-language sql --migrations-dir migrations",
    "test": "NODE_ENV=test jest --runInBand --forceExit",
    "test:watch": "NODE_ENV=test jest --runInBand --watch",
    "test:coverage": "NODE_ENV=test jest --runInBand --forceExit --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "openai": "^4.73.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "playwright": "^1.58.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.8.0",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
