@echo off
setlocal enabledelayedexpansion
node -e "const fs=require('fs'),path=require('path');const files={'src/routes/stories.js':'const express = require(\"express\");const router = express.Router();const db = require(\"../db\");const { scenarioToCsvRows } = require(\"../utils/csvTransformer\");const { verifyToken } = require(\"../middleware/auth\");router.post(\"/:id/export-csv\", verifyToken, async (req, res) => {try{const { id: storyId } = req.params;const userId = req.user.id;if (!storyId) return res.status(400).json({ error: \"Story ID is required\" });const storyQuery = `SELECT id, title, project_id FROM story_ingestions WHERE id = $1 AND user_id = $2`;const storyResult = await db.query(storyQuery, [storyId, userId]);if (storyResult.rows.length === 0) return res.status(404).json({ error: \"Story not found\" });const story = storyResult.rows[0];const reqQuery = `SELECT id FROM story_requirements WHERE story_ingestion_id = $1`;const reqResult = await db.query(reqQuery, [storyId]);if (reqResult.rows.length === 0) return res.status(400).json({ error: \"Story has no requirements extracted\" });const requirementsId = reqResult.rows[0].id;const scenariosQuery = `SELECT id, category, title, summary, preconditions, test_intent, inputs, expected_outcome, priority, dependencies, assumptions FROM coverage_scenarios WHERE story_requirements_id = $1 AND status = \"approved\" ORDER BY category, created_at`;const scenariosResult = await db.query(scenariosQuery, [requirementsId]);if (scenariosResult.rows.length === 0) return res.status(400).json({ error: \"No approved scenarios found. Please approve scenarios before exporting.\" });let csvContent;try{csvContent = scenarioToCsvRows(scenariosResult.rows, story.title);}catch(err){console.error(\"CSV generation error:\", err);return res.status(500).json({ error: \"Failed to generate CSV\" });}const timestamp = new Date().toISOString().split(\"T\")[0];const filename = `testcases-${storyId.slice(0, 8)}-${timestamp}.csv`;res.setHeader(\"Content-Type\", \"text/csv; charset=utf-8\");res.setHeader(\"Content-Disposition\", `attachment; filename=\"${filename}\"`);res.setHeader(\"Cache-Control\", \"no-store, no-cache, must-revalidate\");return res.send(csvContent);}catch(error){console.error(\"[export-csv] Error:\", error);return res.status(500).json({ error: \"Internal server error\" });}}); module.exports = router;'}; Object.entries(files).forEach(([filePath, content]) => { const dir = path.dirname(filePath); if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true }); fs.writeFileSync(filePath, content, 'utf8'); console.log('? Created: ' + filePath); }); console.log('\\n? All files created!');"
pause
